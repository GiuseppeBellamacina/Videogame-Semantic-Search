# ─── Backend (Render) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated list of allowed CORS origins
# Local dev: http://localhost:5173
# Production: add your Vercel frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

HOST=0.0.0.0
PORT=8000

# ─── Upstash Redis (cache persistente) ───────────────────────────────────────
# Crea un db gratuito su https://console.upstash.com
# Se non impostati, il server usa una cache in-memory (persa al riavvio)
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Frontend (Vercel) ───────────────────────────────────────────────────────
# URL of the Render backend (no trailing slash)
# Local dev: leave empty (Vite proxy handles /api → http://localhost:8000)
# Production: set to your Render service URL, e.g. https://your-app.onrender.com
VITE_API_URL=